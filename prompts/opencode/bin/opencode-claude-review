#!/usr/bin/env python3
"""OpenCode Claude CLI helper for non-interactive code review."""

import sys
import os
import subprocess
import json
import argparse
import time
from pathlib import Path

def git_output(path, args, text=True):
    """Run a git command and return output."""
    try:
        result = subprocess.run(["git"] + args, cwd=path, capture_output=True, text=text, check=True)
        return result.stdout
    except FileNotFoundError:
        raise RuntimeError("git command not found")
    except subprocess.CalledProcessError as e:
        err_msg = e.stderr.decode("utf-8", errors="replace") if isinstance(e.stderr, bytes) else e.stderr
        raise RuntimeError(f"git command failed: {err_msg}")

def classify_failure(stderr_output, exit_code):
    """Classify the type of failure from stderr output."""
    stderr_lower = stderr_output.lower()
    # Tightened auth detection - avoid matching substrings like "author"
    if "not authenticated" in stderr_lower:
        return "auth"
    if "authentication failed" in stderr_lower:
        return "auth"
    if "invalid api key" in stderr_lower:
        return "auth"
    if "401" in stderr_output:
        return "auth"
    if "rate limit" in stderr_lower:
        return "rate_limited"
    if "command not found" in stderr_lower:
        return "missing_cli"
    if exit_code == 127:
        return "missing_cli"
    if exit_code == 124:
        return "timeout"
    if "timeout" in stderr_lower:
        return "timeout"
    return "command_failed"

def run_claude(cli_path, prompt, timeout_seconds, model, output_path, stderr_path, 
               allowed_tools=None, bare=True, permission_mode=None, skip_permissions=True, effort="high"):
    """Run Claude CLI with given prompt and capture output."""
    cmd = [cli_path, "-p"]
    
    # Always skip permissions for non-interactive use (can be overridden)
    if skip_permissions:
        cmd.append("--dangerously-skip-permissions")
    
    if bare:
        cmd.append("--bare")
    
    if model:
        cmd.extend(["--model", model])
    
    if effort:
        cmd.extend(["--effort", effort])
    
    if allowed_tools:
        cmd.extend(["--allowedTools", allowed_tools])
    
    if permission_mode:
        cmd.extend(["--permission-mode", permission_mode])
    
    cmd.extend(["--output-format", "text"])
    cmd.append(prompt)
    
    return_code = 0
    try:
        result = subprocess.run(
            cmd,
            timeout=timeout_seconds,
            capture_output=True
        )
        
        with open(output_path, "wb") as f:
            f.write(result.stdout)
        with open(stderr_path, "wb") as f:
            f.write(result.stderr)
            
        success = result.returncode == 0
        return_code = result.returncode
        stderr_str = result.stderr.decode("utf-8", errors="replace")
        
    except subprocess.TimeoutExpired as e:
        success = False
        return_code = 124  # Standard timeout exit code
        # Use specific timeout message, but capture any stderr if available
        timeout_msg = f"timeout after {timeout_seconds}s"
        with open(output_path, "wb") as f:
            f.write(e.stdout if e.stdout else b"[timeout - no output]")
        with open(stderr_path, "wb") as f:
            stderr_bytes = e.stderr if e.stderr else b""
            f.write(stderr_bytes)
        # Build descriptive stderr: timeout message + any actual stderr
        actual_stderr = stderr_bytes.decode("utf-8", errors="replace") if stderr_bytes else ""
        stderr_str = f"{timeout_msg}" + (f"\n{actual_stderr}" if actual_stderr else "")

    except FileNotFoundError:
        success = False
        return_code = 127  # Standard "command not found" exit code
        stderr_str = "claude: command not found"
        with open(output_path, "wb") as f:
            f.write(b"")
        with open(stderr_path, "wb") as f:
            f.write(stderr_str.encode("utf-8"))
    
    reason = None if success else classify_failure(stderr_str, return_code)
    return {"success": success, "reason": reason, "stderr": stderr_str, "return_code": return_code}

def main():
    start_time = time.time()
    
    parser = argparse.ArgumentParser(
        description="OpenCode Claude CLI helper for non-interactive code review."
    )
    parser.add_argument("--repo", default=".", help="Git repository to review")
    parser.add_argument("--ref", default="HEAD", help="Diff baseline ref")
    parser.add_argument("--context-lines", type=int, default=40, help="Git diff context lines")
    parser.add_argument("--model", default="opus", help="Claude model (opus, sonnet, haiku, etc.)")
    parser.add_argument("--effort", default="high", help="Effort level (low, medium, high, xhigh, max)")
    parser.add_argument("--claude-timeout-seconds", type=int, default=120, help="Timeout for Claude calls")
    parser.add_argument("--max-total-seconds", type=int, default=180, help="Max total wall time")
    parser.add_argument("--prompt-file", required=True, help="Path to prompt file")
    parser.add_argument("--output-dir", required=True, help="Output directory for artifacts")
    parser.add_argument("--claude-bin", default=os.environ.get("CLAUDE_BIN", "claude"), 
                        help="Claude CLI executable path")
    parser.add_argument("--allowed-tools", default="Read", 
                        help="Comma-separated list of allowed tools")
    parser.add_argument("--permission-mode", default=None,
                        help="Permission mode (acceptEdits, dontAsk, etc.)")
    parser.add_argument("--bare", action="store_true", default=False,
                        help="Use bare mode (skip auto-discovery, requires ANTHROPIC_API_KEY)")
    parser.add_argument("--no-bare", action="store_false", dest="bare",
                        help="Disable bare mode (default - uses normal auth)")
    parser.add_argument("--skip-permissions", action="store_true", default=True,
                        help="Skip all permission checks (default: true for non-interactive)")
    parser.add_argument("--no-skip-permissions", action="store_false", dest="skip_permissions",
                        help="Require explicit permission approvals")
    parser.add_argument("--verbose", "-v", action="store_true", help="Verbose output")
    args = parser.parse_args()

    def log(msg):
        if args.verbose:
            elapsed = time.time() - start_time
            print(f"[Claude Helper {elapsed:.1f}s] {msg}", file=sys.stderr)

    repo_path = Path(args.repo).resolve()
    out_dir = Path(args.output_dir).resolve()
    out_dir.mkdir(parents=True, exist_ok=True)
    
    log("Reading prompt file...")
    with open(args.prompt_file, "r", encoding="utf-8") as f:
        prompt_template = f.read().strip()
    
    log("Collecting git information...")
    try:
        # Get list of changed files (tracked)
        files_out = git_output(repo_path, ["diff", args.ref, "--name-only"], text=True)
        changed_files = [f for f in files_out.splitlines() if f.strip()]
        
        # Get overall diff (tracked changes)
        bundle_diff = git_output(repo_path, ["diff", f"-U{args.context_lines}", args.ref], text=False)
        
        # Get untracked files (new files not yet staged)
        # Use -z for safe filename parsing (handles special chars, spaces, unicode)
        status_out = git_output(repo_path, ["status", "--porcelain", "-z"], text=False)
        untracked_files = []
        # -z output uses NUL separator, entries are "XY filename\0" or "XY orig\0filename\0" for renames
        entries = status_out.split(b'\x00')
        i = 0
        while i < len(entries):
            entry = entries[i]
            if len(entry) < 3:
                i += 1
                continue
            # Check status code (first 2 chars)
            status_code = entry[:2].decode('ascii', errors='replace')
            # Handle renamed/copied entries: consume 2 entries (orig + new)
            # Match on X column (R/C) to catch all variants: R , RM, RD, C , CM, CD
            if status_code and status_code[0] in ('R', 'C'):
                i += 2  # Skip both orig and new path
                continue
            # Only process untracked entries (??)
            if status_code == "??":
                # Filename starts at position 3 (after "XY " with space separator)
                filename_bytes = entry[3:]
                if filename_bytes:
                    try:
                        filename = filename_bytes.decode("utf-8")
                        untracked_files.append(filename)
                    except UnicodeDecodeError:
                        # Fall back to latin-1 which can decode any byte
                        filename = filename_bytes.decode("latin-1")
                        untracked_files.append(filename)
            i += 1
        
        # Append untracked files to bundle as "new file" diffs
        if untracked_files:
            log(f"Including {len(untracked_files)} untracked file(s)...")
            untracked_content = b"\n"
            for uf in untracked_files:
                file_path = repo_path / uf
                if file_path.is_file():
                    try:
                        # Skip files that are too large (>1MB)
                        file_size = file_path.stat().st_size
                        if file_size > 1024 * 1024:
                            log(f"Skipping large untracked file {uf} ({file_size} bytes)")
                            continue
                        
                        with open(file_path, "rb") as f:
                            content = f.read()
                        
                        # Skip binary files (contain NUL bytes)
                        if b'\x00' in content[:1024]:
                            log(f"Skipping binary untracked file {uf}")
                            continue
                        
                        # Format as a diff for new file
                        untracked_content += f"\ndiff --git a/{uf} b/{uf}\n".encode()
                        untracked_content += f"new file mode 100644\n".encode()
                        untracked_content += f"index 0000000..0000000\n".encode()
                        untracked_content += f"--- /dev/null\n".encode()
                        untracked_content += f"+++ b/{uf}\n".encode()
                        # Add content as a single "added" hunk
                        # Check if file ends with newline
                        ends_with_newline = content.endswith(b"\n")
                        lines = content.split(b"\n")
                        # Remove trailing empty element only if file ends with newline
                        if ends_with_newline and lines and lines[-1] == b"":
                            lines = lines[:-1]
                        untracked_content += f"@@ -0,0 +1,{len(lines)} @@\n".encode()
                        for line in lines:
                            untracked_content += b"+" + line + b"\n"
                        # Add "No newline at end of file" marker if needed
                        if not ends_with_newline:
                            untracked_content += b"\\ No newline at end of file\n"
                        untracked_content += b"\n"
                        changed_files.append(uf + " (new)")
                    except Exception as e:
                        log(f"Warning: Could not read untracked file {uf}: {e}")
            
            bundle_diff = bundle_diff + untracked_content
        
    except RuntimeError as e:
        print(f"Error running git: {e}", file=sys.stderr)
        sys.exit(21)
    
    # Write artifacts
    log(f"Writing bundle ({len(bundle_diff)} bytes, {len(changed_files)} files)...")
    with open(out_dir / "bundle.diff", "wb") as f:
        f.write(bundle_diff)
    with open(out_dir / "files.txt", "w", encoding="utf-8") as f:
        f.write("\n".join(changed_files) + "\n")
    
    # Format prompt with bundle path
    bundle_path = str(out_dir / "bundle.diff")
    formatted_prompt = prompt_template.format(bundle_path=bundle_path)
    
    # Define paths early (needed for pre-flight error handling)
    cli_path = args.claude_bin
    output_path = out_dir / "output.txt"
    stderr_path = out_dir / "stderr.txt"
    summary_path = out_dir / "summary.json"
    
    # Check authentication for bare mode
    if args.bare and not os.environ.get("ANTHROPIC_API_KEY"):
        log("Error: --bare mode requires ANTHROPIC_API_KEY environment variable")
        print("Error: --bare mode requires ANTHROPIC_API_KEY environment variable", file=sys.stderr)
        # Write minimal summary before exit (maintains contract with callers)
        fail_summary = {
            "status": "failed",
            "claude": {"bin": args.claude_bin, "bare_mode": args.bare},
            "failure_reason": "auth_config",
            "duration_seconds": round(time.time() - start_time, 2)
        }
        with open(summary_path, "w", encoding="utf-8") as f:
            json.dump(fail_summary, f, indent=2)
        sys.exit(21)
    
    summary = {
        "status": "failed",
        "claude": {
            "bin": args.claude_bin,
            "model": args.model,
            "effort": args.effort,
            "bare_mode": args.bare,
            "skip_permissions": args.skip_permissions,
            "allowed_tools": args.allowed_tools,
            "permission_mode": args.permission_mode
        },
        "bundle": {
            "size_bytes": len(bundle_diff),
            "file_count": len(changed_files),
            "changed_files": changed_files
        },
        "failure_reason": None,
        "duration_seconds": 0
    }
    
    # Check if max_total_seconds already exceeded
    elapsed_before = time.time() - start_time
    if elapsed_before >= args.max_total_seconds:
        log("Error: max-total-seconds exceeded before starting review")
        summary["status"] = "failed"
        summary["failure_reason"] = "timeout"
        summary["duration_seconds"] = round(elapsed_before, 2)
        with open(summary_path, "w", encoding="utf-8") as f:
            json.dump(summary, f, indent=2)
        sys.exit(20)
    
    # Clamp claude_timeout to remaining budget
    remaining_seconds = args.max_total_seconds - elapsed_before
    # Guard against unusably small time windows (< 5 seconds)
    if remaining_seconds < 5:
        log("Error: remaining time budget too small for meaningful review")
        summary["status"] = "failed"
        summary["failure_reason"] = "timeout"
        summary["duration_seconds"] = round(elapsed_before, 2)
        with open(summary_path, "w", encoding="utf-8") as f:
            json.dump(summary, f, indent=2)
        sys.exit(20)
    effective_timeout = min(args.claude_timeout_seconds, remaining_seconds)
    
    log(f"Starting Claude review (timeout: {effective_timeout:.0f}s)...")
    res = run_claude(
        cli_path, formatted_prompt, effective_timeout, args.model,
        output_path, stderr_path,
        allowed_tools=args.allowed_tools,
        bare=args.bare,
        permission_mode=args.permission_mode,
        skip_permissions=args.skip_permissions,
        effort=args.effort
    )
    
    elapsed = time.time() - start_time
    summary["duration_seconds"] = round(elapsed, 2)
    
    if res["success"]:
        log(f"Claude review succeeded in {elapsed:.1f}s")
        summary["status"] = "success"
        summary["failure_reason"] = None
    else:
        log(f"Claude review failed: {res['reason']}")
        summary["status"] = "failed"
        summary["failure_reason"] = res["reason"]
    
    # Write summary
    with open(summary_path, "w", encoding="utf-8") as f:
        json.dump(summary, f, indent=2)
    
    log(f"Complete. Summary: {summary_path}")
    
    # Exit codes
    if res["success"]:
        sys.exit(0)
    else:
        sys.exit(20)

if __name__ == "__main__":
    main()
