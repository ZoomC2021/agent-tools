#!/usr/bin/env python3
import sys
import os
import subprocess
import json
import argparse
from pathlib import Path
import tempfile
import shutil

from opencode_review_utils import (
    git_output,
    collect_untracked_files,
    synthesize_diff_for_new_file,
    classify_failure,
    write_summary,
)

def build_chunks(files, chunk_bytes):
    chunks = []
    current_chunk = {"files": [], "size_bytes": 0}
    
    for f in files:
        if f["size_bytes"] > chunk_bytes:
            if current_chunk["files"]:
                chunks.append(current_chunk)
                current_chunk = {"files": [], "size_bytes": 0}
            chunks.append({"files": [f["path"]], "size_bytes": f["size_bytes"]})
        elif current_chunk["size_bytes"] + f["size_bytes"] > chunk_bytes:
            chunks.append(current_chunk)
            current_chunk = {"files": [f["path"]], "size_bytes": f["size_bytes"]}
        else:
            current_chunk["files"].append(f["path"])
            current_chunk["size_bytes"] += f["size_bytes"]
            
    if current_chunk["files"]:
        chunks.append(current_chunk)
        
    return chunks

def run_gemini(cli_path, model, prompt_text, timeout_seconds, input_bytes, stdout_path, stderr_path):
    cmd = [cli_path, "--model", model, "-p", prompt_text]
    is_timeout = False
    success = False
    
    try:
        result = subprocess.run(
            cmd,
            input=input_bytes,
            timeout=timeout_seconds + 15,
            capture_output=True
        )
        
        with open(stdout_path, "wb") as f:
            f.write(result.stdout)
        with open(stderr_path, "wb") as f:
            f.write(result.stderr)
            
        success = result.returncode == 0
        stderr_str = result.stderr.decode("utf-8", errors="replace")
    except subprocess.TimeoutExpired as e:
        is_timeout = True
        success = False
        stderr_str = "timeout"
        if e.stdout:
            with open(stdout_path, "wb") as f:
                f.write(e.stdout)
        if e.stderr:
            with open(stderr_path, "wb") as f:
                f.write(e.stderr)
                stderr_str = e.stderr.decode("utf-8", errors="replace")
        else:
            with open(stderr_path, "wb") as f:
                f.write(b"timeout")

    except FileNotFoundError:
        success = False
        stderr_str = "gemini: command not found"
        with open(stderr_path, "wb") as f:
            f.write(stderr_str.encode("utf-8"))
            
    reason = None if success else classify_failure(stderr_str, 124 if is_timeout else (0 if success else 1), is_timeout)
    return {"success": success, "reason": reason}

def make_section(title, files, content):
    section = f"=== {title} ===\n"
    if files:
        section += "Files:\n"
        for f in files:
            section += f"- {f}\n"
    section += "\n" + content.strip() + "\n\n"
    return section.encode("utf-8")

def main():
    parser = argparse.ArgumentParser()
    parser.add_argument("--repo", required=True)
    parser.add_argument("--ref", required=True)
    parser.add_argument("--context-lines", type=int, required=True)
    parser.add_argument("--single-call-bytes", type=int, required=True)
    parser.add_argument("--single-call-files", type=int, required=True)
    parser.add_argument("--chunk-bytes", type=int, required=True)
    parser.add_argument("--gemini-timeout-seconds", type=int, required=True)
    parser.add_argument("--retry-timeout-seconds", type=int, required=True)
    parser.add_argument("--model", required=True)
    parser.add_argument("--prompt-file", required=True)
    parser.add_argument("--output-dir", required=True)
    parser.add_argument("--gemini-bin", default=os.environ.get("GEMINI_BIN", "gemini"), help="Gemini CLI executable path")
    args = parser.parse_args()

    repo_path = Path(args.repo).resolve()
    out_dir = Path(args.output_dir).resolve()
    out_dir.mkdir(parents=True, exist_ok=True)
    
    summary_path = out_dir / "summary.json"
    summary = {
        "status": "failed",
        "mode": "none",
        "failure_reason": None,
        "bundle": {"size_bytes": 0, "file_count": 0},
        "units": {"successful": 0, "total": 0},
        "files": {"successful": [], "failed": []}
    }

    try:
        with open(args.prompt_file, "r", encoding="utf-8") as f:
            prompt_text = f.read().strip()
    except Exception as e:
        summary["failure_reason"] = "prompt_load_error"
        write_summary(summary_path, **summary)
        print(f"Error loading prompt: {e}", file=sys.stderr)
        sys.exit(21)
        
    try:
        # Get list of changed files (tracked)
        files_out = git_output(["diff", args.ref, "--name-only"], repo_path, remaining_seconds=30)
        changed_files = [f for f in files_out.splitlines() if f.strip()]
        # Note: summary["files"]["failed"] will be set after untracked files are processed
        
        # Get overall diff (tracked changes)
        bundle_diff_bytes = git_output(["diff", f"-U{args.context_lines}", args.ref], repo_path, remaining_seconds=30)
        # Ensure we have bytes for concatenation
        if isinstance(bundle_diff_bytes, str):
            bundle_diff = bundle_diff_bytes.encode("utf-8", errors="replace")
        else:
            bundle_diff = bundle_diff_bytes
        
        # Get untracked files (new files not yet staged)
        seen_files = set(changed_files)
        untracked = collect_untracked_files(
            repo_path,
            30,  # timeout
            seen_files,
            args.prompt_file
        )
        
        # Append untracked files to bundle as "new file" diffs
        if untracked:
            print(f"Including {len(untracked)} untracked file(s)...", file=sys.stderr)
            untracked_content = b"\n"
            for uf, content in untracked:
                # Generate synthetic diff with correct git index format
                untracked_content += synthesize_diff_for_new_file(uf, content)
                changed_files.append(uf + " (new)")
            
            bundle_diff = bundle_diff + untracked_content
        
        # Set failed files list now that untracked files are included
        summary["files"]["failed"] = changed_files.copy()
        
    except RuntimeError as e:
        summary["failure_reason"] = "git_error"
        write_summary(summary_path, **summary)
        print(f"Error running git: {e}", file=sys.stderr)
        sys.exit(21)
        
    with open(out_dir / "bundle.diff", "wb") as f:
        f.write(bundle_diff)
    with open(out_dir / "files.txt", "w", encoding="utf-8") as f:
        f.write("\n".join(changed_files) + "\n")
        
    bundle_size = len(bundle_diff)
    file_count = len(changed_files)
    summary["bundle"] = {"size_bytes": bundle_size, "file_count": file_count}
    
    if not changed_files:
        summary["status"] = "success"
        write_summary(summary_path, **summary)
        sys.exit(0)

    cli_path = args.gemini_bin
    combined_output_path = out_dir / "combined_output.txt"
    
    if bundle_size <= args.single_call_bytes and file_count <= args.single_call_files:
        summary["mode"] = "single"
        summary["units"]["total"] = 1
        res = run_gemini(
            cli_path, args.model, prompt_text, args.gemini_timeout_seconds,
            bundle_diff, out_dir / "stdout.txt", out_dir / "stderr.txt"
        )
        if res["success"]:
            summary["status"] = "success"
            summary["units"]["successful"] = 1
            summary["files"]["successful"] = changed_files
            summary["files"]["failed"] = []
            with open(out_dir / "stdout.txt", "rb") as f_in:
                stdout_content = f_in.read()
            with open(combined_output_path, "wb") as f_out:
                f_out.write(make_section("FULL BUNDLE REVIEW", changed_files, stdout_content.decode("utf-8", errors="replace")))
            write_summary(summary_path, **summary)
            sys.exit(0)
        else:
            summary["status"] = "failed"
            summary["failure_reason"] = res["reason"]
            write_summary(summary_path, **summary)
            sys.exit(20)
            
    # Chunked mode
    summary["mode"] = "chunked"
    file_details = []
    for cf in changed_files:
        try:
            cf_diff = git_output(repo_path, ["diff", f"-U{args.context_lines}", args.ref, "--", cf], text=False)
            file_details.append({
                "path": cf,
                "diff_bytes": cf_diff,
                "size_bytes": len(cf_diff)
            })
        except RuntimeError as e:
            print(f"Warning: Failed to get diff for {cf}: {e}", file=sys.stderr)
        
    chunks = build_chunks(file_details, args.chunk_bytes)
    summary["units"]["total"] = len(chunks)
    
    successful_files = []
    failed_files = changed_files.copy()
    
    combined_content = b""
    overall_failure_reason = None
    
    for i, chunk in enumerate(chunks):
        chunk_diff = b"".join([fd["diff_bytes"] for fd in file_details if fd["path"] in chunk["files"]])
        chunk_stdout = out_dir / f"chunk_{i}_stdout.txt"
        chunk_stderr = out_dir / f"chunk_{i}_stderr.txt"
        
        res = run_gemini(
            cli_path, args.model, prompt_text, args.gemini_timeout_seconds,
            chunk_diff, chunk_stdout, chunk_stderr
        )
        
        if res["success"]:
            summary["units"]["successful"] += 1
            successful_files.extend(chunk["files"])
            for f in chunk["files"]:
                if f in failed_files:
                    failed_files.remove(f)
            with open(chunk_stdout, "rb") as f:
                stdout_content = f.read()
            combined_content += make_section(f"CHUNK {i}", chunk["files"], stdout_content.decode("utf-8", errors="replace"))
        else:
            if overall_failure_reason is None:
                overall_failure_reason = res["reason"]

            # Retry per file
            for f in chunk["files"]:
                fd = next((item for item in file_details if item["path"] == f), None)
                if not fd: continue
                f_stdout = out_dir / f"retry_{i}_{f.replace('/', '_')}_stdout.txt"
                f_stderr = out_dir / f"retry_{i}_{f.replace('/', '_')}_stderr.txt"
                retry_res = run_gemini(
                    cli_path, args.model, prompt_text, args.retry_timeout_seconds,
                    fd["diff_bytes"], f_stdout, f_stderr
                )
                if retry_res["success"]:
                    successful_files.append(f)
                    if f in failed_files:
                        failed_files.remove(f)
                    with open(f_stdout, "rb") as f_out:
                        stdout_content = f_out.read()
                    combined_content += make_section(f"RETRY {f}", [f], stdout_content.decode("utf-8", errors="replace"))
                else:
                    if overall_failure_reason is None:
                        overall_failure_reason = retry_res["reason"]

    summary["files"]["successful"] = successful_files
    summary["files"]["failed"] = failed_files
    
    with open(combined_output_path, "wb") as f:
        f.write(combined_content)
        
    if len(failed_files) == 0 and summary["units"]["successful"] > 0:
        summary["status"] = "success"
        write_summary(summary_path, **summary)
        sys.exit(0)
    elif summary["units"]["successful"] > 0 or len(successful_files) > 0:
        summary["status"] = "partial"
        summary["failure_reason"] = overall_failure_reason
        write_summary(summary_path, **summary)
        sys.exit(10)
    else:
        summary["status"] = "failed"
        summary["failure_reason"] = overall_failure_reason
        write_summary(summary_path, **summary)
        sys.exit(20)

if __name__ == "__main__":
    main()
