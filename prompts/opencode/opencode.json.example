              "text"
            ],
            "output": [
              "text"
            ]
          }
        }
      }
    }
  },
  "model": "openai/gpt-5.6-sol",
  "default_agent": "build",
  "mode": {
    "plan": {
      "model": "openai/gpt-5.5"
    },
    "build": {
      "model": "openai/gpt-5.6-sol"
    }
  },
  "agent": {
    "plan": {
      "variant": "high",
      "reasoningEffort": "high"
    },
    "title": {
      "model": "xai/grok-composer-2.5-fast"
    },
    "summary": {
      "model": "xai/grok-composer-2.5-fast"
    },
    "compaction": {
      "model": "xai/grok-composer-2.5-fast"
    },
    "code-review": {
