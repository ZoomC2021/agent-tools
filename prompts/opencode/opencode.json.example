          "change-auditor": "allow",
          "mission-scrutiny": "allow",
          "milestone-validator": "allow",
          "plan-review": "allow"
        }
      },
      "description": "Primary orchestrator agent (frontier-worker variant) - delegates to subagents for specialized tasks"
    },
    "worker-worker": {
      "model": "xai/grok-composer-2.5-fast",
      "prompt": "{file:./agent/worker-worker.md}",
      "permission": {
