{
  "$schema": "https://opencode.ai/config.json",
  "_comment": "OPENCODE CONFIGURATION EXAMPLE - Codex53-Kimi Setup",
  "_security_warning": "⚠️  NEVER commit this file with real API keys to version control. Use environment variables or secure secrets management instead.",
  "_file_placement": {
    "agent_files": "~/.config/opencode/agent/ - Primary agent prompts and subagent prompts (codex53-kimi.md, kimi-general.md, kimi-explore.md, github-librarian.md, docs-research.md, walkthrough.md, oracle.md)",
    "command_prompts": "~/.config/opencode/commands/ - Workflow prompts (review.md, deslop.md, pr-reviewer.md, etc.)",
    "helper_binaries": "~/.config/opencode/bin/ - Helper scripts used by subagents (for example opencode-gh-librarian)",
    "this_config": "~/.config/opencode/opencode.json - Main configuration file"
  },
  "provider": {
    "fireworks-ai": {
      "options": {
        "_apiKey_note": "Use env var: OPENCODE_FIREWORKS_API_KEY or replace with your key (DO NOT COMMIT)",
        "apiKey": "YOUR_FIREWORKS_API_KEY_HERE"
      }
    }
  },
  "model": "fireworks-ai/accounts/fireworks/routers/kimi-k2p5-turbo",
  "default_agent": "codex53-kimi",
  "mode": {
    "plan": {
      "model": "openai/gpt-5.3-codex"
    },
    "build": {
      "model": "fireworks-ai/accounts/fireworks/routers/kimi-k2p5-turbo"
    }
  },
  "agent": {
    "_comment": "AGENT DEFINITIONS - These reference files in ~/.config/opencode/agent/",
    "codex53-kimi": {
      "_description": "Primary orchestrator agent - delegates to subagents for specialized tasks",
      "model": "openai/gpt-5.3-codex",
      "prompt": "{file:./agent/codex53-kimi.md}",
      "permission": {
        "task": {
          "*": "deny",
          "kimi-general": "allow",
          "kimi-explore": "allow",
          "github-librarian": "allow",
          "docs-research": "allow",
          "walkthrough": "allow",
          "review": "allow",
          "deslop": "allow",
          "pr-reviewer": "allow",
          "pr-reviewer-only": "allow",
          "create-pr": "allow",
          "oracle": "allow",
          "spec-compiler": "allow",
          "quick-validator": "allow",
          "change-auditor": "allow"
        }
      },
      "routing_policy": {
        "description": "Deterministic agent selection based on request type. Always include 'Agent chosen + reason' in final response.",
        "rules": [
          {
            "trigger": "PR creation or opening",
            "keywords": ["create PR", "open PR", "pull request", "new PR"],
            "agent": "create-pr",
            "reason": "PR creation workflow requires specialized commit/branch/PR handling"
          },
          {
            "trigger": "PR comments or feedback handling",
            "keywords": ["PR comment", "review feedback", "address PR", "fix PR"],
            "agent": "pr-reviewer",
            "reason": "PR feedback requires GitHub API integration and structured response handling"
          },
          {
            "trigger": "Plan/prompt-only PR review",
            "keywords": ["PR review plan", "PR prompt only", "generate PR fix plan"],
            "agent": "pr-reviewer-only",
            "reason": "User requested implementation plan without direct changes"
          },
          {
            "trigger": "Code quality or principles audit",
            "keywords": ["audit", "code quality", "principles", "deslop", "clean code"],
            "agent": "deslop",
            "reason": "Quality audits require specialized coding principles analysis"
          },
          {
            "trigger": "Uncommitted changes review",
            "keywords": ["review changes", "uncommitted", "git diff review", "pre-commit review"],
            "agent": "review",
            "reason": "Review agent specializes in local change validation and quick remediation"
          },
          {
            "trigger": "Remote GitHub code research",
            "keywords": ["github.com/", "owner/repo", "upstream repo", "remote repo", "reference implementation"],
            "agent": "github-librarian",
            "reason": "Remote repository analysis should use a dedicated GitHub research worker"
          },
          {
            "trigger": "Official docs, API behavior, migration notes, release notes",
            "keywords": ["official docs", "documentation", "api docs", "migration guide", "release notes", "how does"],
            "agent": "docs-research",
            "reason": "External behavior questions should be grounded in authoritative documentation"
          },
          {
            "trigger": "Local architecture walkthrough and diagrams",
            "keywords": ["walk me through", "show the flow", "diagram", "architecture", "how does this work"],
            "agent": "walkthrough",
            "reason": "Architecture explanations deserve a dedicated evidence-backed walkthrough agent"
          },
          {
            "trigger": "Discovery and search only",
            "keywords": ["find", "search", "discover", "explore", "locate", "where is"],
            "agent": "kimi-explore",
            "reason": "Read-only exploration should use lightweight discovery agent"
          },
          {
            "trigger": "Implementation, debugging, refactoring, execution",
            "keywords": ["implement", "fix", "debug", "refactor", "build", "execute", "create", "add", "change"],
            "agent": "kimi-general",
            "reason": "General worker for concrete execution tasks when no specialized agent matches"
          }
        ],
        "fallback_rule": {
          "condition": "No specialized agent matches the request type",
          "action": "Use kimi-general for execution/debugging, kimi-explore for local read-only discovery, and specialized research agents for external docs or remote repositories"
        },
        "enforcement": {
          "specialized_priority": "If a specialized agent exists for the request type, do NOT use kimi-general unless specialized agent returns BLOCKED",
          "response_requirement": "Every final user-facing response MUST include: 'Agent chosen: <agent_name> + Reason: <routing_reason>'"
        }
      }
    },
    "github-librarian": {
      "_description": "Read-only remote GitHub code research on default branches with lightweight history",
      "mode": "subagent",
      "model": "fireworks-ai/accounts/fireworks/routers/kimi-k2p5-turbo",
      "hidden": true,
      "prompt": "{file:./agent/github-librarian.md}",
      "permission": {
        "task": {
          "*": "deny"
        },
        "read": "allow",
        "bash": "allow"
      }
    },
    "docs-research": {
      "_description": "Research official documentation, API behavior, and release notes",
      "mode": "subagent",
      "model": "fireworks-ai/accounts/fireworks/routers/kimi-k2p5-turbo",
      "hidden": true,
      "prompt": "{file:./agent/docs-research.md}",
      "permission": {
        "task": {
          "*": "deny"
        },
        "read": "allow",
        "webfetch": "allow",
        "websearch": "allow"
      }
    },
    "walkthrough": {
      "_description": "Explain local architecture and generate Mermaid walkthroughs",
      "mode": "subagent",
      "model": "fireworks-ai/accounts/fireworks/routers/kimi-k2p5-turbo",
      "hidden": true,
      "prompt": "{file:./agent/walkthrough.md}",
      "permission": {
        "task": {
          "*": "deny"
        },
        "read": "allow",
        "bash": "allow"
      }
    },
    "oracle": {
      "_description": "Deep reasoning agent for complex problems - GPT-5.4 powered",
      "model": "openai/gpt-5.4",
      "prompt": "{file:./agent/oracle.md}",
      "permission": {
        "task": {
          "*": "deny",
          "oracle-consult": "allow"
        }
      }
    },
    "kimi-general": {
      "_description": "General worker for implementation, debugging, refactoring, execution",
      "mode": "subagent",
      "model": "fireworks-ai/accounts/fireworks/routers/kimi-k2p5-turbo",
      "hidden": true,
      "prompt": "{file:./agent/kimi-general.md}"
    },
    "kimi-explore": {
      "_description": "Lightweight read-only discovery and search agent",
      "mode": "subagent",
      "model": "fireworks-ai/accounts/fireworks/routers/kimi-k2p5-turbo",
      "hidden": true,
      "prompt": "{file:./agent/kimi-explore.md}",
      "permission": {
        "task": { "*": "deny" },
        "read": "allow",
        "bash": "allow"
      }
    },
    "review": {
      "_description": "Review uncommitted changes and report/fix issues",
      "mode": "subagent",
      "model": "openai/gpt-5.3-codex",
      "hidden": true,
      "prompt": "{file:./prompts/review.md}"
    },
    "deslop": {
      "_description": "Detect and prioritize code quality violations",
      "mode": "subagent",
      "model": "fireworks-ai/accounts/fireworks/routers/kimi-k2p5-turbo",
      "hidden": true,
      "prompt": "{file:./prompts/deslop.md}"
    },
    "refactor": {
      "_description": "Analyze and prioritize refactoring opportunities",
      "mode": "subagent",
      "model": "fireworks-ai/accounts/fireworks/routers/kimi-k2p5-turbo",
      "hidden": true,
      "prompt": "{file:./prompts/refactor.md}"
    },
    "pr-reviewer": {
      "_description": "Fetch PR feedback and apply fixes on the PR branch",
      "mode": "subagent",
      "model": "fireworks-ai/accounts/fireworks/routers/kimi-k2p5-turbo",
      "hidden": true,
      "prompt": "{file:./prompts/pr-reviewer.md}"
    },
    "pr-reviewer-only": {
      "_description": "Fetch PR feedback and produce an implementation prompt",
      "mode": "subagent",
      "model": "fireworks-ai/accounts/fireworks/routers/kimi-k2p5-turbo",
      "hidden": true,
      "prompt": "{file:./prompts/pr-reviewer-only.md}"
    },
    "create-pr": {
      "_description": "Create a pull request from current git changes",
      "mode": "subagent",
      "model": "fireworks-ai/accounts/fireworks/routers/kimi-k2p5-turbo",
      "hidden": true,
      "prompt": "{file:./prompts/create-pr.md}"
    },
    "spec-compiler": {
      "_description": "Compile Execution Contract before implementation work (Phase 1)",
      "mode": "subagent",
      "model": "openai/gpt-5.3-codex",
      "hidden": true,
      "prompt": "{file:./prompts/spec-compiler.md}"
    },
    "quick-validator": {
      "_description": "Run quick validation checks on implementation output (Phase 3)",
      "mode": "subagent",
      "model": "fireworks-ai/accounts/fireworks/routers/kimi-k2p5-turbo",
      "hidden": true,
      "prompt": "{file:./prompts/quick-validator.md}"
    },
    "change-auditor": {
      "_description": "Deep audit for high-risk changes, security, breaking changes (Phase 4, optional)",
      "mode": "subagent",
      "model": "openai/gpt-5.3-codex",
      "hidden": true,
      "prompt": "{file:./prompts/change-auditor.md}"
    }
  },
  "_reference_setup": {
    "note": "This configuration enables deterministic routing between specialized subagents",
    "architecture": "codex53-kimi (orchestrator) -> subagents (kimi-general, kimi-explore, github-librarian, docs-research, walkthrough, review, deslop, pr-reviewer, create-pr)",
    "workflow": "4-phase implementation: spec-compiler -> kimi-general -> quick-validator -> change-auditor (optional)",
    "local_reference": "~/.config/opencode/agent/ contains agent definitions, ~/.config/opencode/commands/ contains workflow prompts, ~/.config/opencode/bin/ contains helper scripts"
  }
}
