      "variant": "high",
      "reasoningEffort": "high"
    },
    "frontier-worker": {
      "model": "openai/gpt-5.5",
      "reasoningEffort": "high",
      "prompt": "{file:./agent/frontier-worker.md}",
      "permission": {
        "task": {
          "*": "deny",
          "worker-general": "allow",
          "worker-explore": "allow",
          "github-librarian": "allow",
          "docs-research": "allow",
          "walkthrough": "allow",
          "review": "allow",
          "adversarial-review": "allow",
          "thermo-nuclear-code-quality-review": "allow",
          "deslop": "allow",
          "pr-reviewer": "allow",
          "pr-reviewer-only": "allow",
          "create-pr": "allow",
          "oracle": "allow",
          "spec-compiler": "allow",
