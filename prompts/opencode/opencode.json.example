{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "fireworks-ai": {
      "options": {
        "apiKey": "YOUR_FIREWORKS_API_KEY"
      }
    }
  },
  "model": "fireworks-ai/accounts/fireworks/routers/kimi-k2p5-turbo",
  "default_agent": "codex53-kimi",
  "mode": {
    "plan": {
      "model": "openai/gpt-5.3-codex"
    },
    "build": {
      "model": "fireworks-ai/accounts/fireworks/routers/kimi-k2p5-turbo"
    }
  },
  "agent": {
    "codex53-kimi": {
      "model": "openai/gpt-5.3-codex",
      "prompt": "{file:./agent/codex53-kimi.md}",
      "permission": {
        "task": {
          "*": "deny",
          "kimi-general": "allow",
          "kimi-explore": "allow",
          "review": "allow",
          "deslop": "allow",
          "pr-reviewer": "allow",
          "pr-reviewer-only": "allow",
          "create-pr": "allow",
          "oracle": "allow"
        }
      }
    },
    "oracle": {
      "model": "openai/gpt-5.4",
      "prompt": "{file:./agent/oracle.md}",
      "permission": {
        "task": {
          "*": "deny",
          "oracle-consult": "allow"
        }
      }
    }
  }
}
