    "google": {
      "models": {
        "gemini-3-pro-high": {
          "name": "Gemini 3 Pro High (Antigravity)",
          "limit": {
            "context": 1048576,
            "output": 65535
          },
          "modalities": {
            "input": ["text", "image", "pdf"],
            "output": ["text"]
          }
        },
        "gemini-3-pro-low": {
          "name": "Gemini 3 Pro Low (Antigravity)",
          "limit": {
            "context": 1048576,
            "output": 65535
          },
          "modalities": {
            "input": ["text", "image", "pdf"],
            "output": ["text"]
          }
        },
        "gemini-3-flash": {
          "name": "Gemini 3 Flash (Antigravity)",
          "limit": {
            "context": 1048576,
            "output": 65536
          },
          "modalities": {
            "input": ["text", "image", "pdf"],
            "output": ["text"]
          }
        },
        "claude-sonnet-4-5": {
          "name": "Claude Sonnet 4.5 (Antigravity)",
          "limit": {
            "context": 200000,
            "output": 64000
          },
          "modalities": {
            "input": ["text", "image", "pdf"],
            "output": ["text"]
          }
        },
        "claude-sonnet-4-5-thinking": {
          "name": "Claude Sonnet 4.5 Thinking (Antigravity)",
          "limit": {
            "context": 200000,
            "output": 64000
          },
          "modalities": {
            "input": ["text", "image", "pdf"],
            "output": ["text"]
          }
        },
        "claude-opus-4-5-thinking": {
          "name": "Claude Opus 4.5 Thinking (Antigravity)",
          "limit": {
            "context": 200000,
            "output": 64000
          },
          "modalities": {
            "input": ["text", "image", "pdf"],
            "output": ["text"]
          }
        },
        "gpt-oss-120b-medium": {
          "name": "GPT-OSS 120B Medium (Antigravity)",
          "limit": {
            "context": 131072,
            "output": 32768
          },
          "modalities": {
            "input": ["text", "image", "pdf"],
            "output": ["text"]
          }
        }
      }
    },
    "fireworks-ai": {
      "options": {
        "apiKey": "YOUR_FIREWORKS_API_KEY_HERE"
      },
      "models": {
        "accounts/fireworks/routers/kimi-k2p5-turbo": {
          "name": "Kimi 2.5 Turbo (Fireworks)",
          "limit": {
            "context": 256000,
            "output": 256000
          },
          "modalities": {
            "input": ["text"],
            "output": ["text"]
          },
          "cost": {
            "input": 0.99,
            "output": 4.94,
            "cache": {
              "read": 0.16,
              "write": 0.99
            }
          }
        }
      }
    }
  },
  "model": "fireworks-ai/accounts/fireworks/routers/kimi-k2p5-turbo",
  "default_agent": "codex53-kimi-turbo",
  "mode": {
    "plan": {
      "model": "openai/gpt-5.3-codex"
    },
    "build": {
      "model": "fireworks-ai/accounts/fireworks/routers/kimi-k2p5-turbo"
    }
  },
  "agent": {
    "plan": {
      "variant": "high",
      "reasoningEffort": "high"
    },
    "title": {
      "model": "fireworks-ai/accounts/fireworks/routers/kimi-k2p5-turbo"
    },
    "summary": {
      "model": "fireworks-ai/accounts/fireworks/routers/kimi-k2p5-turbo"
    },
    "compaction": {
      "model": "fireworks-ai/accounts/fireworks/routers/kimi-k2p5-turbo"
    },
    "code-review": {
      "model": "openai/gpt-5.3-codex",
      "variant": "high",
      "reasoningEffort": "high"
    },
    "codex53-kimi": {
      "model": "openai/gpt-5.3-codex",
      "prompt": "{file:./agent/codex53-kimi.md}",
      "permission": {
        "task": {
          "*": "deny",
          "kimi-general": "allow",
          "kimi-explore": "allow",
          "github-librarian": "allow",
          "docs-research": "allow",
          "walkthrough": "allow",
          "review": "allow",
          "deslop": "allow",
          "pr-reviewer": "allow",
          "pr-reviewer-only": "allow",
          "create-pr": "allow",
          "oracle": "allow",
          "spec-compiler": "allow",
          "quick-validator": "allow",
          "change-auditor": "allow",
          "mission-scrutiny": "allow",
          "milestone-validator": "allow",
          "plan-review": "allow"
        }
      },
      "description": "Primary orchestrator agent (GPT 5.3 Codex) - delegates to subagents for specialized tasks"
    },
    "codex53-kimi-turbo": {
      "model": "fireworks-ai/accounts/fireworks/routers/kimi-k2p5-turbo",
      "prompt": "{file:./agent/codex53-kimi-turbo.md}",
      "permission": {
        "task": {
          "*": "deny",
          "kimi-general": "allow",
          "kimi-explore": "allow",
          "github-librarian": "allow",
          "docs-research": "allow",
          "walkthrough": "allow",
          "review": "allow",
          "deslop": "allow",
          "pr-reviewer": "allow",
          "pr-reviewer-only": "allow",
          "create-pr": "allow",
          "oracle": "allow",
          "spec-compiler": "allow",
          "quick-validator": "allow",
          "change-auditor": "allow",
          "mission-scrutiny": "allow",
          "milestone-validator": "allow",
          "plan-review": "allow"
        }
      },
      "description": "Primary orchestrator agent (Kimi 2.5 Turbo) - delegates to subagents for specialized tasks"
    },
    "github-librarian": {
      "description": "Read-only remote GitHub code research on default branches with lightweight history.",
      "mode": "subagent",
      "model": "fireworks-ai/accounts/fireworks/routers/kimi-k2p5-turbo",
      "hidden": true,
      "prompt": "{file:./agent/github-librarian.md}",
      "permission": {
        "task": {
          "*": "deny"
        },
        "read": "allow",
        "bash": "allow"
      }
    },
    "docs-research": {
      "description": "Research official documentation, API behavior, and release notes.",
      "mode": "subagent",
      "model": "fireworks-ai/accounts/fireworks/routers/kimi-k2p5-turbo",
      "hidden": true,
      "prompt": "{file:./agent/docs-research.md}",
      "permission": {
        "task": {
          "*": "deny"
        },
        "read": "allow",
        "webfetch": "allow",
        "websearch": "allow"
      }
    },
    "walkthrough": {
      "description": "Explain local architecture and generate Mermaid walkthroughs.",
      "mode": "subagent",
      "model": "fireworks-ai/accounts/fireworks/routers/kimi-k2p5-turbo",
      "hidden": true,
      "prompt": "{file:./agent/walkthrough.md}",
      "permission": {
        "task": {
          "*": "deny"
        },
        "read": "allow",
        "bash": "allow"
      }
    },
    "oracle": {
      "model": "openai/gpt-5.4",
      "prompt": "{file:./agent/oracle.md}",
      "reasoningEffort": "high",
      "permission": {
        "task": {
          "*": "deny",
          "oracle-consult": "allow"
        }
      }
    },
    "review": {
      "description": "Review uncommitted changes and report/fix issues.",
      "mode": "subagent",
      "model": "openai/gpt-5.3-codex",
      "hidden": true,
      "prompt": "{file:./commands/review.md}",
      "reasoningEffort": "high"
    },
    "ultrareview": {
      "description": "Parallel dual-model review using GPT 5.4 (OpenCode) AND Gemini 3.1 Pro Preview (Gemini CLI with helper-managed bundling/chunking/retries).",
      "mode": "subagent",
      "model": "fireworks-ai/accounts/fireworks/routers/kimi-k2p5-turbo",
      "hidden": true,
      "prompt": "{file:./commands/ultrareview.md}"
    },
    "ultrareview-lite": {
      "description": "Parallel dual-model review using Kimi 2.5 Turbo (OpenCode) AND Gemini 3 Flash Preview (Gemini CLI with helper-managed bundling/chunking/retries).",
      "mode": "subagent",
      "model": "fireworks-ai/accounts/fireworks/routers/kimi-k2p5-turbo",
      "hidden": true,
      "prompt": "{file:./commands/ultrareview-lite.md}"
    },
    "cc": {
      "description": "Execute Claude CLI commands and code reviews from OpenCode via the Agent SDK CLI.",
      "mode": "subagent",
      "model": "fireworks-ai/accounts/fireworks/routers/kimi-k2p5-turbo",
      "hidden": true,
      "prompt": "{file:./commands/cc.md}"
    },
    "refactor": {
      "description": "Analyze and prioritize refactoring opportunities.",
      "mode": "subagent",
      "model": "fireworks-ai/accounts/fireworks/routers/kimi-k2p5-turbo",
      "hidden": true,
      "prompt": "{file:./commands/refactor.md}"
    },
    "deslop": {
      "description": "Detect and prioritize code quality violations.",
      "mode": "subagent",
      "model": "fireworks-ai/accounts/fireworks/routers/kimi-k2p5-turbo",
      "hidden": true,
      "prompt": "{file:./commands/deslop.md}"
    },
    "pr-reviewer": {
      "description": "Fetch PR feedback and apply fixes on the PR branch.",
      "mode": "subagent",
      "model": "fireworks-ai/accounts/fireworks/routers/kimi-k2p5-turbo",
      "hidden": true,
      "prompt": "{file:./commands/pr-reviewer.md}"
    },
    "pr-reviewer-only": {
      "description": "Fetch PR feedback and produce an implementation prompt.",
      "mode": "subagent",
      "model": "fireworks-ai/accounts/fireworks/routers/kimi-k2p5-turbo",
      "hidden": true,
      "prompt": "{file:./commands/pr-reviewer-only.md}"
    },
    "create-pr": {
      "description": "Create a pull request from current git changes.",
      "mode": "subagent",
      "model": "fireworks-ai/accounts/fireworks/routers/kimi-k2p5-turbo",
      "hidden": true,
      "prompt": "{file:./commands/create-pr.md}"
    },
    "spec-compiler": {
      "description": "Compile Execution Contract before implementation work.",
      "mode": "subagent",
      "model": "fireworks-ai/accounts/fireworks/routers/kimi-k2p5-turbo",
      "hidden": true,
      "prompt": "{file:./commands/spec-compiler.md}"
    },
    "kimi-general": {
      "description": "Concrete implementation, debugging, refactoring, and execution tasks.",
      "mode": "subagent",
      "model": "fireworks-ai/accounts/fireworks/routers/kimi-k2p5-turbo",
      "hidden": true,
      "prompt": "{file:./agent/kimi-general.md}",
      "permission": {
        "task": {
          "*": "deny"
        },
        "read": "allow",
        "bash": "allow",
        "edit": "allow",
        "glob": "allow",
        "grep": "allow"
      }
    },
    "kimi-explore": {
      "description": "Read-only local codebase discovery and search.",
      "mode": "subagent",
      "model": "fireworks-ai/accounts/fireworks/routers/kimi-k2p5-turbo",
      "hidden": true,
      "prompt": "{file:./agent/kimi-explore.md}",
      "permission": {
        "task": {
          "*": "deny"
        },
        "read": "allow",
        "glob": "allow",
        "grep": "allow"
      }
    },
    "quick-validator": {
      "description": "Run quick validation checks on implementation output.",
      "mode": "subagent",
      "model": "fireworks-ai/accounts/fireworks/routers/kimi-k2p5-turbo",
      "hidden": true,
      "prompt": "{file:./commands/quick-validator.md}"
    },
    "change-auditor": {
      "description": "Deep audit for high-risk changes (security, breaking changes).",
      "mode": "subagent",
      "model": "openai/gpt-5.3-codex",
      "hidden": true,
      "prompt": "{file:./commands/change-auditor.md}",
      "reasoningEffort": "high"
    },
    "mission-scrutiny": {
      "description": "Front-load scrutiny and milestone planning for long-running multi-step tasks.",
      "mode": "subagent",
      "model": "openai/gpt-5.3-codex",
      "hidden": true,
      "prompt": "{file:./commands/mission-scrutiny.md}"
    },
    "milestone-validator": {
      "description": "Validate each milestone before the next milestone begins.",
      "mode": "subagent",
      "model": "openai/gpt-5.3-codex",
      "hidden": true,
      "prompt": "{file:./commands/milestone-validator.md}"
    },
    "plan-review": {
      "description": "Binary validation of Execution Contracts (Momus-style: approve 80% clear plans, reject only true blockers).",
      "mode": "subagent",
      "model": "fireworks-ai/accounts/fireworks/routers/kimi-k2p5-turbo",
      "hidden": true,
      "prompt": "{file:./commands/plan-review.md}",
      "permission": {
        "task": {
          "*": "deny"
        },
        "read": "allow",
        "bash": "allow",
        "glob": "allow",
        "grep": "allow"
      }
    },
    "handoff": {
      "description": "Generate handoff context for continuing work in a new session",
      "mode": "subagent",
      "model": "fireworks-ai/accounts/fireworks/routers/kimi-k2p5-turbo",
      "hidden": true,
      "prompt": "{file:./commands/handoff.md}",
      "permission": {
        "read": "allow",
        "bash": "allow",
        "glob": "allow",
        "grep": "allow",
        "write": "deny"
      }
    }
  }
}
