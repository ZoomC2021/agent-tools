        }
      },
      "description": "Primary orchestrator agent (worker-worker variant) - delegates to subagents for specialized tasks"
    },
    "github-librarian": {
      "description": "Read-only remote GitHub code research on default branches with lightweight history.",
      "mode": "subagent",
      "model": "xai/grok-composer-2.5-fast",
