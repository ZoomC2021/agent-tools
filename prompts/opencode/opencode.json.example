{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "fireworks-ai": {
      "options": {
        "apiKey": "YOUR_FIREWORKS_API_KEY_HERE"
      }
    }
  },
  "model": "fireworks-ai/accounts/fireworks/routers/kimi-k2p5-turbo",
  "default_agent": "codex53-kimi",
  "mode": {
    "plan": {
      "model": "openai/gpt-5.3-codex"
    },
    "build": {
      "model": "fireworks-ai/accounts/fireworks/routers/kimi-k2p5-turbo"
    }
  },
  "agent": {
    "codex53-kimi": {
      "model": "openai/gpt-5.3-codex",
      "prompt": "{file:./agent/codex53-kimi.md}",
      "permission": {
        "task": {
          "*": "deny",
          "kimi-general": "allow",
          "kimi-explore": "allow",
          "github-librarian": "allow",
          "docs-research": "allow",
          "walkthrough": "allow",
          "review": "allow",
          "deslop": "allow",
          "pr-reviewer": "allow",
          "pr-reviewer-only": "allow",
          "create-pr": "allow",
          "oracle": "allow",
          "mission-scrutiny": "allow",
          "spec-compiler": "allow",
          "milestone-validator": "allow",
          "quick-validator": "allow",
          "change-auditor": "allow"
        }
      },
      "routing_policy": {
        "description": "Deterministic agent selection based on request type. Always include 'Agent chosen + reason' in final response.",
        "rules": [
          {
            "trigger": "PR creation or opening",
            "keywords": [
              "create PR",
              "open PR",
              "pull request",
              "new PR"
            ],
            "agent": "create-pr",
            "reason": "PR creation workflow requires specialized commit/branch/PR handling"
          },
          {
            "trigger": "PR comments or feedback handling",
            "keywords": [
              "PR comment",
              "review feedback",
              "address PR",
              "fix PR"
            ],
            "agent": "pr-reviewer",
            "reason": "PR feedback requires GitHub API integration and structured response handling"
          },
          {
            "trigger": "Plan/prompt-only PR review",
            "keywords": [
              "PR review plan",
              "PR prompt only",
              "generate PR fix plan"
            ],
            "agent": "pr-reviewer-only",
            "reason": "User requested implementation plan without direct changes"
          },
          {
            "trigger": "Code quality or principles audit",
            "keywords": [
              "audit",
              "code quality",
              "principles",
              "deslop",
              "clean code"
            ],
            "agent": "deslop",
            "reason": "Quality audits require specialized coding principles analysis"
          },
          {
            "trigger": "Uncommitted changes review",
            "keywords": [
              "review changes",
              "uncommitted",
              "git diff review",
              "pre-commit review"
            ],
            "agent": "review",
            "reason": "Review agent specializes in local change validation and quick remediation"
          },
          {
            "trigger": "Remote GitHub code research",
            "keywords": [
              "github.com/",
              "owner/repo",
              "upstream repo",
              "remote repo",
              "reference implementation"
            ],
            "agent": "github-librarian",
            "reason": "Remote repository analysis should use a dedicated GitHub research worker"
          },
          {
            "trigger": "Official docs, API behavior, migration notes, release notes",
            "keywords": [
              "official docs",
              "documentation",
              "api docs",
              "migration guide",
              "release notes",
              "how does"
            ],
            "agent": "docs-research",
            "reason": "External behavior questions should be grounded in authoritative documentation"
          },
          {
            "trigger": "Local architecture walkthrough and diagrams",
            "keywords": [
              "walk me through",
              "show the flow",
              "diagram",
              "architecture",
              "how does this work"
            ],
            "agent": "walkthrough",
            "reason": "Architecture explanations deserve a dedicated evidence-backed walkthrough agent"
          },
          {
            "trigger": "Discovery and search only",
            "keywords": [
              "find",
              "search",
              "discover",
              "explore",
              "locate",
              "where is"
            ],
            "agent": "kimi-explore",
            "reason": "Read-only exploration should use lightweight discovery agent"
          },
          {
            "trigger": "Implementation, debugging, refactoring, execution",
            "keywords": [
              "implement",
              "fix",
              "debug",
              "refactor",
              "build",
              "execute",
              "create",
              "add",
              "change"
            ],
            "agent": "kimi-general",
            "reason": "General worker for concrete execution tasks when no specialized agent matches; large multi-step tasks add mission-scrutiny and milestone-validator around it"
          }
        ],
        "mission_workflow": {
          "trigger": "Large or long-running multi-step implementation",
          "conditions": [
            "User explicitly asks for long-running, multi-step, migration, rewrite, prototype, or end-to-end work",
            "Task includes 3+ deliverables or workstreams",
            "Task spans 2+ major surfaces with dependencies",
            "Scrutiny/contract estimates Large effort or more than 1 milestone"
          ],
          "phases": [
            "mission-scrutiny",
            "spec-compiler per milestone",
            "kimi-general per milestone",
            "milestone-validator per milestone",
            "quick-validator final pass",
            "change-auditor optional high-risk pass"
          ]
        },
        "fallback_rule": {
          "condition": "No specialized agent matches the request type",
          "action": "Use kimi-general for execution/debugging, kimi-explore for local read-only discovery, and specialized research agents for external docs or remote repositories"
        },
        "enforcement": {
          "specialized_priority": "If a specialized agent exists for the request type, do NOT use kimi-general unless specialized agent returns BLOCKED",
          "response_requirement": "Every final user-facing response MUST include: 'Agent chosen: <agent_name> + Reason: <routing_reason>'; mission-style tasks should also report scrutiny and milestone outcomes"
        }
      },
      "description": "Primary orchestrator agent - delegates to subagents for specialized tasks"
    },
    "github-librarian": {
      "mode": "subagent",
      "model": "fireworks-ai/accounts/fireworks/routers/kimi-k2p5-turbo",
      "hidden": true,
      "prompt": "{file:./agent/github-librarian.md}",
      "permission": {
        "task": {
          "*": "deny"
        },
        "read": "allow",
        "bash": "allow"
      },
      "description": "Read-only remote GitHub code research on default branches with lightweight history"
    },
    "docs-research": {
      "mode": "subagent",
      "model": "fireworks-ai/accounts/fireworks/routers/kimi-k2p5-turbo",
      "hidden": true,
      "prompt": "{file:./agent/docs-research.md}",
      "permission": {
        "task": {
          "*": "deny"
        },
        "read": "allow",
        "webfetch": "allow",
        "websearch": "allow"
      },
      "description": "Research official documentation, API behavior, and release notes"
    },
    "walkthrough": {
      "mode": "subagent",
      "model": "fireworks-ai/accounts/fireworks/routers/kimi-k2p5-turbo",
      "hidden": true,
      "prompt": "{file:./agent/walkthrough.md}",
      "permission": {
        "task": {
          "*": "deny"
        },
        "read": "allow",
        "bash": "allow"
      },
      "description": "Explain local architecture and generate Mermaid walkthroughs"
    },
    "oracle": {
      "model": "openai/gpt-5.4",
      "prompt": "{file:./agent/oracle.md}",
      "permission": {
        "task": {
          "*": "deny",
          "oracle-consult": "allow"
        }
      },
      "description": "Deep reasoning agent for complex problems - GPT-5.4 powered"
    },
    "mission-scrutiny": {
      "mode": "subagent",
      "model": "openai/gpt-5.3-codex",
      "hidden": true,
      "prompt": "{file:./commands/mission-scrutiny.md}",
      "description": "Front-load scrutiny and milestone planning for long-running multi-step tasks"
    },
    "kimi-general": {
      "mode": "subagent",
      "model": "fireworks-ai/accounts/fireworks/routers/kimi-k2p5-turbo",
      "hidden": true,
      "prompt": "{file:./agent/kimi-general.md}",
      "description": "General worker for implementation, debugging, refactoring, execution"
    },
    "kimi-explore": {
      "mode": "subagent",
      "model": "fireworks-ai/accounts/fireworks/routers/kimi-k2p5-turbo",
      "hidden": true,
      "prompt": "{file:./agent/kimi-explore.md}",
      "permission": {
        "task": {
          "*": "deny"
        },
        "read": "allow",
        "bash": "allow"
      },
      "description": "Lightweight read-only discovery and search agent"
    },
    "review": {
      "mode": "subagent",
      "model": "openai/gpt-5.3-codex",
      "hidden": true,
      "prompt": "{file:./commands/review.md}",
      "description": "Review uncommitted changes and report/fix issues"
    },
    "deslop": {
      "mode": "subagent",
      "model": "fireworks-ai/accounts/fireworks/routers/kimi-k2p5-turbo",
      "hidden": true,
      "prompt": "{file:./commands/deslop.md}",
      "description": "Detect and prioritize code quality violations"
    },
    "refactor": {
      "mode": "subagent",
      "model": "fireworks-ai/accounts/fireworks/routers/kimi-k2p5-turbo",
      "hidden": true,
      "prompt": "{file:./commands/refactor.md}",
      "description": "Analyze and prioritize refactoring opportunities"
    },
    "pr-reviewer": {
      "mode": "subagent",
      "model": "fireworks-ai/accounts/fireworks/routers/kimi-k2p5-turbo",
      "hidden": true,
      "prompt": "{file:./commands/pr-reviewer.md}",
      "description": "Fetch PR feedback and apply fixes on the PR branch"
    },
    "pr-reviewer-only": {
      "mode": "subagent",
      "model": "fireworks-ai/accounts/fireworks/routers/kimi-k2p5-turbo",
      "hidden": true,
      "prompt": "{file:./commands/pr-reviewer-only.md}",
      "description": "Fetch PR feedback and produce an implementation prompt"
    },
    "create-pr": {
      "mode": "subagent",
      "model": "fireworks-ai/accounts/fireworks/routers/kimi-k2p5-turbo",
      "hidden": true,
      "prompt": "{file:./commands/create-pr.md}",
      "description": "Create a pull request from current git changes"
    },
    "spec-compiler": {
      "mode": "subagent",
      "model": "fireworks-ai/accounts/fireworks/routers/kimi-k2p5-turbo",
      "hidden": true,
      "prompt": "{file:./commands/spec-compiler.md}",
      "description": "Compile Execution Contract before implementation work (Phase 1)"
    },
    "milestone-validator": {
      "mode": "subagent",
      "model": "openai/gpt-5.3-codex",
      "hidden": true,
      "prompt": "{file:./commands/milestone-validator.md}",
      "description": "Validate each milestone before the next milestone begins"
    },
    "quick-validator": {
      "mode": "subagent",
      "model": "fireworks-ai/accounts/fireworks/routers/kimi-k2p5-turbo",
      "hidden": true,
      "prompt": "{file:./commands/quick-validator.md}",
      "description": "Run quick validation checks on implementation output (Phase 3)"
    },
    "change-auditor": {
      "mode": "subagent",
      "model": "openai/gpt-5.3-codex",
      "hidden": true,
      "prompt": "{file:./commands/change-auditor.md}",
      "description": "Deep audit for high-risk changes, security, breaking changes (Phase 4, optional)"
    }
  }
}
