          "name": "Nemotron 3 Ultra Free (Nous Research)",
          "limit": {
            "context": 1000000,
            "output": 16384
          },
          "modalities": {
            "input": [
              "text"
            ],
            "output": [
              "text"
            ]
          }
        },
        "stepfun/step-3.7-flash:free": {
          "name": "StepFun Step 3.7 Flash Free (Nous Research)",
          "limit": {
            "context": 256000,
            "output": 256000
          },
          "modalities": {
            "input": [
              "text",
              "image"
            ],
            "output": [
              "text"
            ]
          }
        }
      }
    },
    "xai": {
      "models": {
        "grok-composer-2.5-fast": {
          "name": "Grok Composer 2.5 Fast"
        }
      }
    },
    "zerog": {
      "options": {
        "apiKey": "{env:ZEROG_API_KEY}",
        "baseURL": "https://router-api.0g.ai/v1"
      },
      "models": {
        "minimax-m3": {
